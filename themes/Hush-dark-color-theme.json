  "tokenColors": [
    {
      "name": "Comments: Line",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.line",
        "comment.line punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#e47ef9"
      }
    },
    {
      "name": "Comments: Block",
      "scope": [
        "comment.block",
        "comment.documentation",
        "comment.block punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#e47ef9"
      }
    },
    {
      "name": "Invalid - Illegal",
      "scope": "invalid.illegal",
      "settings": {
        "foreground": "#fe827b"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.accessor",
        "punctuation.terminator",
        "keyword.operator.assignment",
        "meta.arrow storage.type.function.arrow",
        "meta.separator.markdown",
        "meta.field.declaration keyword.operator"
      ],
      "settings": {
        "foreground": "#7E7E97"
      }
    },
    {
      "name": "HTML: Doctype Declaration",
      "scope": [
        "meta.tag.metadata.doctype.html",
        "meta.tag.metadata.doctype.html entity.name.tag",
        "meta.tag.metadata.doctype.html punctuation.definition.tag",
        "meta.tag.sgml.doctype",
        "meta.tag.sgml.doctype string",
        "meta.tag.sgml.doctype entity.name.tag",
        "meta.tag.sgml punctuation.definition.tag.html"
      ],
      "settings": {
        "foreground": "#7E7E97"
      }
    },
    {
      "name": "HTML: Tag Names",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "HTML/JSX: Attribute Names",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#D0D0D9"
      }
    },
    {
      "name": "HTML/JSX: Tag Punctuation",
      "scope": [
        "punctuation.definition.tag",
        "punctuation.definition.tag.begin",
        "punctuation.definition.tag.end"
      ],
      "settings": {
        "foreground": "#7E7E97"
      }
    },
    {
      "name": "Type keyword",
      "scope": [
        "keyword.control.type"
      ],
      "settings": {
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "Type definition",
      "scope": [
        "meta.var-single-variable entity.name.type",
        "meta.interface.ts entity.name.type.interface.ts",
        "meta.interface.ts entity.name.type.interface.ts"
      ],
      "settings": {
        "foreground": "#A984FF"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "meta.tag support.class.component",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#FF923F"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "keyword.operator.logical",
        "keyword.operator.comparison",
        "keyword.operator.arithmetic",
        "meta.field.declaration keyword.operator.optional"
      ],
      "settings": {
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "Types",
      "scope": [
        "storage.type",
        "support.type"
      ],
      "settings": {
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "Function Definitions",
      "scope": [
        "meta.definition.function entity.name.function",
        "meta.function entity.name.function",
        "entity.name.function"
      ],
      "settings": {
        "foreground": "#FF923F"
      }
    },
    {
      "name": "Import/Export Statements",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "meta.export variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#FF923F"
      }
    },
    {
      "name": "Variable Definitions",
      "scope": [
        "meta.definition.variable",
        "meta.definition variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#A984FF"
      }
    },
    {
      "name": "Object keys",
      "scope": [
        "meta.object-literal.key",
        "meta.definition.property variable.object.property"
      ],
      "settings": {
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "Variable Uses",
      "scope": [
        "meta variable.other.readwrite",
        "meta.embedded.line variable.other",
        "meta.embedded.line meta.function-call",
        "meta.function-call entity.name.function"
      ],
      "settings": {
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "Type References",
      "scope": [
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "CSS: Selectors",
      "scope": [
        "meta.selector",
        "meta.selector entity",
        "meta.selector entity punctuation",
        "meta.selector.css punctuation.definition.entity",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#FF923F"
      }
    },
    {
      "name": "Exceptions",
      "scope": "entity.name.exception",
      "settings": {
        "foreground": "#fe827b"
      }
    },
    {
      "name": "Numbers, Characters",
      "scope": [
        "constant.numeric",
        "constant.character"
      ],
      "settings": {
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "constant.language",
        "support.constant",
        "variable.language",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "Strings",
      "scope": "string",
      "settings": {
        "foreground": "#58b6ab"
      }
    },
    {
      "name": "String punctuation",
      "scope": "string punctuation.definition.string",
      "settings": {
        "foreground": "#45736d"
      }
    },
    {
      "name": "CSS: Property Values",
      "scope": [
        "meta.property-value",
        "meta.property-value constant.other",
        "support.constant.property-value"
      ],
      "settings": {
        "foreground": "#58b6ab"
      }
    },
    {
      "name": "Strings: Regular Expressions",
      "scope": "string.regexp",
      "settings": {
        "foreground": "#58b6ab"
      }
    },
    {
      "name": "HTML: Entities",
      "scope": [
        "constant.character.entity",
        "punctuation.definition.entity"
      ],
      "settings": {
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "Strings: Escape Sequences",
      "scope": "constant.character.escape",
      "settings": {
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "Numerical operators",
      "scope": [
        "keyword.operator.increment",
        "storage.type.numeric.bigint"
      ],
      "settings": {
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "Regex: Operators and Keywords",
      "scope": [
        "string.regexp keyword",
        "string.regexp keyword.operator"
      ],
      "settings": {
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "CSS: Important Keyword",
      "scope": "keyword.other.important",
      "settings": {
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup: Changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "Markup: Deletion",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "Sections",
      "scope": "entity.name.section",
      "settings": {
        "fontStyle": "bold",
        "foreground": "#FF923F"
      }
    },
    {
      "name": "Markup: Emphasis",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "Markup: Strong",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "fontStyle": "bold",
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "Markup: Link",
      "scope": "meta.link",
      "settings": {
        "foreground": "#6cc1b2"
      }
    },
    {
      "name": "Markup: Heading",
      "scope": "markup.heading",
      "settings": {
        "foreground": "#6cc1b2"
      }
    },
    {
      "name": "Markup: Error",
      "scope": "markup.error",
      "settings": {
        "foreground": "#ffaca8"
      }
    },
    {
      "name": "Markup: Insertion",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#EBEBEF"
      }
    },
    {
      "name": "Markup: Output",
      "scope": [
        "markup.output",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#D0D0D9"
      }
    },
    {
      "name": "Markup: Prompt",
      "scope": "markup.prompt",
      "settings": {
        "foreground": "#D0D0D9"
      }
    },
    {
      "name": "Markup: Traceback",
      "scope": "markup.traceback",
      "settings": {
        "foreground": "#ffaca8"
      }
    },
    {
      "name": "Markup: Underline",
      "scope": "markup.underline",
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markup Inline",
      "scope": "markup.inline.raw",
      "settings": {
        "fontStyle": "",
        "foreground": "#A984FF"
      }
    },
    {
      "name": "Markup Punctuation",
      "scope": [
        "markup.list punctuation.definition.list",
        "markup.quote punctuation.definition.quote",
        "markup.fenced_code.block punctuation.definition.markdown",
        "markup.fenced_code.block fenced_code.block.language"
      ],
      "settings": {
        "fontStyle": "",
        "foreground": "#5d99ff"
      }
    },
    {
      "name": "Extra: Diff Range",
      "scope": [
        "meta.diff.range",
        "meta.diff.index",
        "meta.separator"
      ],
      "settings": {
        "foreground": "#D0D0D9"
      }
